{
  "name": "@walkie-talkie/react",
  "version": "1.0.2",
  "description": "React hooks and components for walkie-talkie terminal servers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "walkie-talkie",
    "terminal",
    "react",
    "xterm",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "@walkie-talkie/client": "workspace:*",
    "@walkie-talkie/shared": "workspace:*"
  },
  "peerDependencies": {
    "@xterm/addon-fit": ">=0.10.0",
    "@xterm/xterm": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@xterm/addon-fit": {
      "optional": true
    },
    "@xterm/xterm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
